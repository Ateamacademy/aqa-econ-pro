# Copy this file to .env and fill in the values.
# These are Supabase publishable (client-side) values, safe for the browser bundle.
# Do NOT put the Supabase service_role key or any server-only secret in here.

SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

VITE_SUPABASE_URL=
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
